MLIR_SYS_200_PREFIX=/usr/lib/llvm-20
TABLEGEN_200_PREFIX=/usr/lib/llvm-20
RUSTFLAGS=-L /usr/lib/llvm-20/lib
LLZK_SYS_ENABLE_WHOLE_ARCHIVE=1
LLVM_DIR=/usr/lib/llvm-20/lib/cmake/llvm
MLIR_DIR=/usr/lib/llvm-20/lib/cmake/mlir
Clang_DIR=/usr/lib/llvm-20/lib/cmake/clang
LLVM_BIN=/usr/lib/llvm-20/bin/
ASAN_SYMBOLIZER_PATH=/usr/lib/llvm-20/bin/llvm-symbolizer
CC=/usr/lib/llvm-20/bin/clang
CXX=/usr/lib/llvm-20/bin/clang++
